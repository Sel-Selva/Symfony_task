# Symfony default ignores

# Dependencies

/vendor/
/node_modules/

# Environment files

.env
.env.local
.env.*.local

# Symfony var directory (cache, logs, sessions)

/var/

# Composer

composer.phar

# PHPUnit

/phpunit.xml
/phpunit.xml.dist

# Build / frontend

/public/build/
/public/bundles/

# Logs

*.log

# OS / IDE files

.DS_Store
Thumbs.db
.idea/
.vscode/

# Symfony CLI binary

.symfony/

# Docker overrides

docker-compose.override.yml

# Cache and temp

*.cache
*.tmp

# Database

*.sqlite

# Secrets (Symfony 4+)

config/secrets/prod/prod.decrypt.private.php
config/secrets/*/*.decrypt.private.php

# Webpack Encore

node_modules/
npm-debug.log*
yarn-error.log*
